{
  "id": "com.prudencia.hikvision-axpro",
  "version": "0.1.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "platforms": ["local"],
  "name": { "en": "Hikvision AX PRO" },
  "description": { "en": "Local control and monitoring for Hikvision AX PRO wireless alarm panels (DS-PWA96). Arm/disarm, per-detector temperature, door/contact, motion, tamper and battery." },
  "category": ["security"],
  "brandColor": "#E30613",
  "permissions": [],
  "author": { "name": "Ulf Holmström", "email": "ulf@prudsec.se" },
  "images": { "small": "/assets/images/small.png", "large": "/assets/images/large.png" },
  "drivers": [
    {
      "id": "panel",
      "name": { "en": "AX PRO Panel" },
      "class": "homealarm",
      "capabilities": ["homealarm_state"],
      "images": { "small": "/drivers/panel/assets/images/small.png", "large": "/drivers/panel/assets/images/large.png" },
      "pair": [
        { "id": "connect" },
        { "id": "list_devices", "template": "list_devices", "navigation": { "next": "add_devices" } },
        { "id": "add_devices", "template": "add_devices" }
      ]
    }
  ]
}
